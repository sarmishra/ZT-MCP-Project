# ZT-MCP Framework Configuration
DEPLOYMENT_MODE=adaptive  # Options: strict, adaptive, audit-only
ZTMCP_GATEWAY_PORT=8000

# Access Policy Engine (APE)
OPA_SERVER_URL=http://localhost:8181/v1/data/ztmcp/allow

# Protocol Audit Logger (PAL)
DATABASE_URL=postgresql://ztmcp_admin:secure_dev_password@localhost:5432/ztmcp_audit
PAL_HMAC_SECRET=your_cryptographic_secret_here_replace_in_production

# Tool Identity Verifier (TIV)
TIV_STRICT_CERT_CHECK=true
